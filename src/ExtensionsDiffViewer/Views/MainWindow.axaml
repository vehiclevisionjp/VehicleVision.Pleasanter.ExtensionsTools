<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:vm="using:VehicleVision.Pleasanter.ExtensionsTools.DiffViewer.ViewModels"
        x:Class="VehicleVision.Pleasanter.ExtensionsTools.DiffViewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Extensions Diff Viewer - プリザンター拡張機能 差分ビューア"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- 上部: 設定パネル -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="12,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,12,Auto,*,12,Auto,*,12,Auto,12,Auto" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="Base URL:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding BaseUrl}" Watermark="https://pleasanter.example.com" />

                <TextBlock Grid.Column="3" Text="API Key:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="4" Text="{Binding ApiKey}" PasswordChar="●" Watermark="API キー" />

                <TextBlock Grid.Column="6" Text="Parameters:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="7" Text="{Binding ParametersPath}" Watermark="/path/to/Parameters" />

                <Button Grid.Column="9" Content="比較" Command="{Binding CompareCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Classes="accent" Padding="16,6" />

                <StackPanel Grid.Column="11" Orientation="Horizontal" Spacing="4">
                    <Button Content="全件 Pull ↓" Command="{Binding PullAllCommand}"
                            IsEnabled="{Binding !IsLoading}" Padding="12,6" />
                    <Button Content="全件 Push ↑" Command="{Binding PushAllCommand}"
                            IsEnabled="{Binding !IsLoading}" Padding="12,6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 下部: ステータスバー -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" Padding="12,6" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="一致: " /><Run Text="{Binding UnchangedCount}" Foreground="#4CAF50" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="変更: " /><Run Text="{Binding ModifiedCount}" Foreground="#FF9800" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="サーバーのみ: " /><Run Text="{Binding ServerOnlyCount}" Foreground="#2196F3" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="ローカルのみ: " /><Run Text="{Binding LocalOnlyCount}" Foreground="#9C27B0" FontWeight="Bold" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- メイン: 3 カラムレイアウト -->
        <Grid ColumnDefinitions="280,Auto,*">

            <!-- 左ペイン: 差分一覧 -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="拡張機能一覧" Classes="section-header" Margin="8,8,8,4" />
                    <ListBox ItemsSource="{Binding DiffItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:DiffItemViewModel">
                                <Border Padding="6,4" CornerRadius="4">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" />
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="{Binding StatusColor}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="4" Background="#E0E0E0" />

            <!-- 右ペイン: 左右分割ペイン（サーバー vs ローカル） -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <!-- 操作ボタン -->
                <Border Grid.Row="0" Background="#FAFAFA" Padding="8,6" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Content="Pull（サーバー → ローカル）→" Command="{Binding PullSelectedCommand}"
                                IsEnabled="{Binding CanPullSelected}" Padding="16,6" />
                        <Button Content="← Push（ローカル → サーバー）" Command="{Binding PushSelectedCommand}"
                                IsEnabled="{Binding CanPushSelected}" Padding="16,6" />
                    </StackPanel>
                </Border>

                <!-- 左右ペイン -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">
                    <!-- 左: サーバー（DB） -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="8,6">
                            <TextBlock Text="サーバー（DB）" Classes="section-header" Foreground="#1565C0" />
                        </Border>
                        <ae:TextEditor x:Name="ServerEditor"
                                        FontFamily="Cascadia Code, Consolas, monospace"
                                        FontSize="13"
                                        IsReadOnly="True"
                                        ShowLineNumbers="True"
                                        WordWrap="False"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto" />
                    </DockPanel>

                    <!-- スプリッター -->
                    <GridSplitter Grid.Column="1" Width="4" Background="#E0E0E0" />

                    <!-- 右: ローカル（ファイル） -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top" Background="#F3E5F5" Padding="8,6">
                            <TextBlock Text="ローカル（ファイル）" Classes="section-header" Foreground="#7B1FA2" />
                        </Border>
                        <ae:TextEditor x:Name="LocalEditor"
                                        FontFamily="Cascadia Code, Consolas, monospace"
                                        FontSize="13"
                                        IsReadOnly="True"
                                        ShowLineNumbers="True"
                                        WordWrap="False"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto" />
                    </DockPanel>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
